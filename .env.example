# Copie para ".env" e preencha. O ".env" não é versionado.

# Pausa "humana" entre ações do robô (ms)
ACTION_DELAY_MS=700

# Paciência com a Amazon (lenta): tempo máx. por ação/página, em ms (padrão 2 min).
# Aumente se a conta estiver muito travada.
NAV_TIMEOUT_MS=120000

# ─── Cérebro central (Neon Postgres) ───────────────────────────────────────
# Pegue em https://console.neon.tech → projeto frete-amazon-robo → Connection string
NEON_PROJECT_ID=
DATABASE_URL=
