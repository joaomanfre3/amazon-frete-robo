{
  "name": "amazon-frete-robo",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Robô Playwright para criar tabelas de frete na Amazon Seller Central — janela própria (Electron) + CLI, suporte a múltiplas empresas.",
  "main": "desktop/main.js",
  "scripts": {
    "app": "electron .",
    "start": "node src/index.js",
    "list": "node src/index.js list",
    "setup": "npm install && npx playwright install chrome && node scripts/gerar-template.js",
    "gerar-template": "node scripts/gerar-template.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "inquirer": "^9.2.0",
    "playwright": "^1.48.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zinn.amazonfreterobo",
    "productName": "Robo Frete Amazon",
    "files": [
      "desktop/**",
      "src/**",
      "template/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/playwright/**",
      "node_modules/playwright-core/**"
    ],
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "empresas/.gitkeep",
        "to": "empresas/.gitkeep"
      }
    ]
  }
}
